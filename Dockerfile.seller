# Seller API only — Node monorepo build.
# Railway: Settings → set builder to "Dockerfile", path: Dockerfile.seller, root: / (repo root).
# Or use Railpack with RAILPACK_BUILD_CMD (see docs/RAILWAY.md).

FROM node:22-bookworm-slim

WORKDIR /app

# Full tree so npm workspaces + lockfile match (dashboard/swarm are present but not built here).
COPY . .

RUN npm ci \
  && npm run build -w @nanometer/seller-api

ENV NODE_ENV=production
EXPOSE 3001

CMD ["node", "apps/seller-api/dist/index.js"]
