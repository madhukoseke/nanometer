# Swarm controller — Node monorepo build (sister to Dockerfile.seller).
# Railway: Settings → Builder → Docker, Dockerfile path: Dockerfile.swarm, root: / (repo root).

FROM node:22-bookworm-slim

WORKDIR /app

COPY . .

RUN npm ci \
  && npm run build -w @nanometer/swarm

ENV NODE_ENV=production
# Railway injects PORT; 3002 is the local default in server.ts.
EXPOSE 3002

CMD ["node", "apps/swarm/dist/server.js"]
