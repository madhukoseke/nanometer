# Where the seller API is hosted. The dashboard proxies its SSE feed.
NEXT_PUBLIC_SELLER_URL=http://localhost:3001

# Where the swarm controller is hosted. The "Start swarm" button hits this.
NEXT_PUBLIC_SWARM_URL=http://localhost:3002

# Optional: direct Supabase reads (the shipped UI uses SSE only; enable if you add client queries)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
