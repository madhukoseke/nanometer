# Where the seller API is hosted (SSE: /events). Must match the swarm’s SELLER_URL when using a deployed seller.
# Local: http://localhost:3001  —  Vercel + Railway: https://your-seller.up.railway.app
NEXT_PUBLIC_SELLER_URL=http://localhost:3001

# Swarm control plane. Local: 3002 — deployed: https://your-swarm.up.railway.app
NEXT_PUBLIC_SWARM_URL=http://localhost:3002

# Optional — override Settlement tx explorer base (default: https://testnet.arcscan.app/tx)
# NEXT_PUBLIC_ARC_EXPLORER_TX_BASE=https://testnet.arcscan.app/tx

# Optional: direct Supabase reads (the shipped UI uses SSE only; enable if you add client queries)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
