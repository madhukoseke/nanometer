# Wallet that receives all paid USDC. This is the "seller" address.
# Get one from the Circle Developer Console or use any EVM address you control.
SELLER_ADDRESS=0x0000000000000000000000000000000000000000

# Networks accepted by createGatewayMiddleware. Default to Arc testnet.
# CAIP-2 format: eip155:<chainId>. Arc testnet chainId is 5042002.
NETWORKS=eip155:5042002

# Supabase (free tier is fine). Service-role key — server-side only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...

# Server port
PORT=3001

# Circle Gateway (testnet for Arc sepolia / hackathon). Override for mainnet.
GATEWAY_FACILITATOR_URL=https://gateway-api-testnet.circle.com
