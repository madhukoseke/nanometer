# 5 agent wallet private keys, comma-separated. These are funded buyer wallets
# that have already deposited USDC into Circle Gateway via the bootstrap script.
#
# DO NOT use mainnet keys here. Testnet only. Each key starts with 0x.
AGENT_KEYS=0xdeadbeef...,0xfeedcafe...,0xc0ffee...,0xfacefeed...,0xbaadf00d...

# The seller API URL (where the swarm sends paid requests).
SELLER_URL=http://localhost:3001

# Chain — must match what the seller accepts.
CHAIN=arcTestnet

# Swarm controller port (the dashboard's "Start swarm" button hits this).
SWARM_PORT=3002

# How long a swarm run lasts in seconds (90 = matches the demo script).
RUN_DURATION_SEC=90

# Target requests per second across all 5 agents.
TARGET_RPS=12
